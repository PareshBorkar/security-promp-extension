{
  "manifest_version": 3,
  "name": "Security Prompt Scanner",
  "version": "0.1.0",
  "description": "Detect security risks in prompts and text inputs.",
  "permissions": ["activeTab", "storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["scanner.js", "content.js"],
      "css": ["styles.css"]
    }
  ]
}